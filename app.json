{
  "expo": {
    "name": "Plazly",
    "slug": "kribb-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/plazly.png",
    "scheme": "plazly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/plazly.png",
      "bundleIdentifier": "com.bolucodes.kribbapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/plazly.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.bolucodes.kribbapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/main-plazly.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Plazly to access your location to tag property coordinates"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/main-plazly.png",
          "android": {
            "image": "./assets/images/main-plazly.png",
            "imageWidth": 76
          }
        }
      ],
      "@clerk/expo",
      "expo-secure-store",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9741d9f9-1b7e-41fd-a35c-6fdb52010b62"
      }
    },
    "owner": "bolucodes",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9741d9f9-1b7e-41fd-a35c-6fdb52010b62"
    }
  }
}
